# TLE API Environment Variables

# Database connection string
ConnectionStrings__Default=Host=localhost;Database=meolut;Username=postgres;Password=postgres

# TLE table name (optional, defaults to "tle")
Tle__TableName=tle

# Enable Swagger in production (optional, defaults to false in production)
Swagger__Enabled=true

# Application environment
ASPNETCORE_ENVIRONMENT=Development

# URLs to listen on
ASPNETCORE_URLS=http://0.0.0.0:5000
