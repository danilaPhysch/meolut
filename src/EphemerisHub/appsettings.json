{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=0.0.0.0;Port=5432;Database=ephemerishub;Username=<USERNAME>;Password=<PASSWORD>"
  },
  "Rinex": {
    "BaseUrl": "https://cddis.nasa.gov/archive/gnss/data/daily/",
    "DownloadDirectory": "./downloads",
    "ScheduleInterval": "24:00:00",
    "MaxRetryAttempts": 3,
    "RetryDelay": "00:05:00",
    "AutoDownload": true,
    "DaysToDownload": 1
  },
  "Logging": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Information"
      }
    }
  }
}
